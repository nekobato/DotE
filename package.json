{
  "name": "dot-e",
  "version": "0.0.22",
  "author": {
    "name": "nekobato",
    "email": "nekobato@gmail.com"
  },
  "license": "MIT",
  "description": "Fediverse client for desktop",
  "repository": {
    "type": "git",
    "url": "https://github.com/nekobato/dote.git"
  },
  "scripts": {
    "prepare": "rm -rf node_modules/electron/dist && node node_modules/electron/install.js",
    "dev": "vite",
    "build": "pnpm prepare && vue-tsc && vite build && electron-builder --config electron-builder.config.cjs",
    "release": "pnpm build && electron-builder --publish always -c --config electron-builder.config.cjs",
    "build:icon": "electron-icon-builder --input=./public/images/logo/icon.png --output=./public",
    "typecheck": "vue-tsc --noEmit && tsc --noEmit",
    "press": "vitepress dev docs",
    "docs:dev": "vitepress dev docs",
    "docs:build": "vitepress build docs",
    "docs:preview": "vitepress preview docs",
    "website:dev": "vitepress dev website",
    "website:build": "vitepress build website",
    "website:preview": "vitepress preview website"
  },
  "engines": {
    "node": ">=20",
    "pnpm": ">=8"
  },
  "main": "./dist-electron/index.js",
  "dependencies": {
    "@atproto/api": "0.20.5",
    "@atproto/jwk-jose": "0.2.0",
    "@atproto/oauth-client": "0.7.1",
    "@atproto/oauth-client-node": "0.4.0",
    "electron-fetch": "1.9.1",
    "electron-log": "5.4.4",
    "electron-store": "11.0.2",
    "electron-updater": "6.8.3",
    "font-list": "2.1.0"
  },
  "devDependencies": {
    "@iconify/vue": "5.0.1",
    "@vitejs/plugin-vue": "6.0.7",
    "@vitejs/plugin-vue-jsx": "5.1.5",
    "@vueuse/core": "14.3.0",
    "bowser": "2.14.1",
    "electron": "42.2.0",
    "electron-builder": "26.8.1",
    "electron-icon-builder": "2.0.1",
    "element-plus": "2.14.0",
    "mfm-js": "0.26.0",
    "misskey-js": "2026.5.4",
    "nanoid": "5.1.11",
    "pinia": "3.0.4",
    "postcss-html": "1.8.1",
    "prettier": "3.8.3",
    "sass-embedded": "1.100.0",
    "stylelint": "17.12.0",
    "stylelint-config-rational-order": "0.1.2",
    "stylelint-config-recommended-scss": "17.0.1",
    "stylelint-config-recommended-vue": "1.6.1",
    "stylelint-order": "8.1.1",
    "typescript": "6.0.3",
    "vite": "8.0.14",
    "vite-plugin-electron": "0.29.1",
    "vite-plugin-electron-renderer": "0.14.7",
    "vite-plugin-resolve": "2.5.2",
    "vitepress": "1.6.4",
    "vue": "3.5.34",
    "vue-router": "5.0.7",
    "vue-tsc": "3.3.1"
  },
  "packageManager": "pnpm@11.2.2"
}
